#!/bin/bash
# post-commit dispatcher — executes hooks from core/ then project/
# Install: .gaai/project/scripts/install-hooks.sh

ROOT="$(git rev-parse --show-toplevel)"
CORE_DIR="$ROOT/.gaai/core/hooks/post-commit.d"
PROJECT_DIR="$ROOT/.gaai/project/hooks/post-commit.d"

for dir in "$CORE_DIR" "$PROJECT_DIR"; do
    [ -d "$dir" ] || continue
    for script in "$dir"/*; do
        [ -x "$script" ] || continue
        "$script" || echo "⚠️  $(basename "$dir")/../$(basename "$script") failed (non-blocking)"
    done
done

exit 0
